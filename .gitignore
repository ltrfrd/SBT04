# ===========================================================
# .gitignore
# -----------------------------------------------------------
# Prevents Git from tracking system files, environment files,
# virtual-env packages, compiled code, and temporary data.
# ===========================================================

# --- Virtual environment folders ---
venv/                 # Local Python virtual environment directory
ENV/                  # Alternate name some setups use

# --- Python cache & compiled files ---
__pycache__/          # Bytecode cache automatically generated by Python
*.pyc                 # Compiled Python files
*.pyo                 # Optimized bytecode
*.pyd                 # Windows-specific compiled modules

# --- Environment & configuration secrets ---
.env                  # Local environment variables (DATABASE_URL, SECRET_KEY)
*.env                 # Any other environment file variants

# --- Database files (for SQLite dev only) ---
*.db                  # SQLite database files created in development
*.sqlite3             # Alternative SQLite extension

# --- IDE and editor metadata ---
.vscode/              # Visual Studio Code settings folder
.idea/                # JetBrains / PyCharm project folder
*.code-workspace      # VS Code workspace files

# --- OS-specific junk ---
.DS_Store             # macOS Finder metadata
Thumbs.db             # Windows thumbnail cache

# --- Alembic migration cache ---
alembic/versions/__pycache__/   # Ignore compiled Alembic migration cache

# --- Logs & temporary files ---
*.log                 # Log files
*.tmp                 # Temporary files
*.bak                 # Backup files

# --- Build / distribution artifacts (future use) ---
dist/
build/
# -----------------------------------------------------------
# Python cache
# -----------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# -----------------------------------------------------------
# Local databases
# -----------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal

# -----------------------------------------------------------
# Alembic cache
# -----------------------------------------------------------
alembic/**/__pycache__/

# -----------------------------------------------------------
# Virtual env
# -----------------------------------------------------------
venv/
.venv/
# -----------------------------------------------------------
# Pytest cache / temp directories
# -----------------------------------------------------------
.pytest_cache/
.pytest_tmp/
pytest_tmp*
pytest_cache*
tests/pytest*

# temp / backup files
*.bak
*.bak*
